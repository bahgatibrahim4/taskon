{
  "name": "taskon-desktop",
  "version": "1.0.0",
  "description": "TASKON - نظام إدارة المشاريع والمقاولات",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node setup-default-data.js",
    "electron": "electron .",
    "electron-dev": "set NODE_ENV=development && electron .",
    "build-win": "electron-builder --win --x64",
    "build-win32": "electron-builder --win --ia32",
    "build-all": "electron-builder --win --x64 --ia32"
  },
  "build": {
    "appId": "com.taskon.app",
    "productName": "TASKON",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "favicon.ico",
      "artifactName": "TASKON-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TASKON",
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico",
      "installerHeaderIcon": "favicon.ico",
      "language": "1025"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules/.cache",
      "!*.log",
      "!.git",
      "!.gitignore",
      "!README.md"
    ]
  },
  "dependencies": {
    "cloudinary": "^1.37.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "gridfs-stream": "^1.1.1",
    "mongodb": "^6.18.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "taskon",
    "construction",
    "management",
    "contractors",
    "express",
    "mongodb",
    "electron",
    "desktop"
  ],
  "author": "Bahgat Ibrahim",
  "license": "ISC"
}
